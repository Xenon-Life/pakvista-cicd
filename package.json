{
  "name": "pakvista-cicd",
  "version": "1.0.0",
  "description": "Multi-environment CI/CD pipeline for the PakVista static web application",
  "scripts": {
    "lint:html": "htmlhint \"*.html\"",
    "lint:css": "stylelint \"*.css\"",
    "lint": "npm run lint:html && npm run lint:css",
    "build": "parcel build index.html lahore.html hunza.html karachi.html swat.html --dist-dir dist --public-url ./",
    "start": "parcel index.html"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Xenon-Life/pakvista-cicd.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Xenon-Life/pakvista-cicd/issues"
  },
  "homepage": "https://github.com/Xenon-Life/pakvista-cicd#readme",
  "devDependencies": {
    "htmlhint": "^1.9.2",
    "parcel": "^2.16.4",
    "stylelint": "^17.13.0",
    "stylelint-config-standard": "^40.0.0"
  }
}
